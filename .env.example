# Copy file ini ke .env dan isi dengan nilai dari Firebase Console
# Firebase Project Settings → General → Your apps → SDK setup

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Cloud Messaging — untuk push notification
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_VAPID_KEY=your_vapid_public_key_here
